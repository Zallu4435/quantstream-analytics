# ──────────────────────────────────────────────────────────
# Crypto Analytics Platform — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── Kafka (Local) ────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=raw-ticks
KAFKA_TOPIC_ALERTS=alerts

# ── Upstash Redis — Cloud ───────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Neon (Postgres) — Cloud ─────────────────────────────
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech:5432/crypto_analytics?sslmode=require
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=10

# ── Aiven (TimescaleDB) — Cloud ─────────────────────────
TIMESCALE_URL=postgresql://user:password@your-aiven-host.aivencloud.com:12345/defaultdb?sslmode=require

# ── API Gateway ─────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── Producer Service ────────────────────────────────────
SYMBOLS=btcusdt,ethusdt,solusdt

# ── WebSocket Service ───────────────────────────────────
WS_PORT=4100

# ── Auth Service ────────────────────────────────────────
AUTH_PORT=4001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
