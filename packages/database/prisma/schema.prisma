// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Market Data Models ─────────────────────────────────────



model Candle {
  id        String   @default(cuid())
  symbol    String
  interval  String   // e.g., "1m", "5m"
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  timestamp DateTime
  createdAt DateTime @default(now())

  @@id([id, timestamp])
  @@unique([symbol, interval, timestamp])
  @@index([symbol, timestamp])
  @@map("candles")
}


model Alert {
  id            String   @id @default(cuid())
  type          String
  symbol        String
  price         Float
  previousPrice Float
  changePercent Float
  message       String
  timestamp     DateTime
  createdAt     DateTime @default(now())

  @@index([symbol, timestamp])
  @@index([type])
  @@map("alerts")
}

